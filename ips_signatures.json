{
  "_comment": "IPSシグネチャ定義。GitHubで一元管理し、全デプロイがここから読み込む。patternはPython re のバイト列パターン（latin-1）。binary=trueは印字可能判定をスキップ。cve/description/recommended_action/reference は検知時の対応判断用メタデータ（任意）。",
  "version": "2026.07.08.2",
  "signatures": [
    {
      "id": "WEB-SQLI-1",
      "category": "SQLインジェクション",
      "severity": "high",
      "binary": false,
      "pattern": "(?i)(union\\s+select|'\\s*or\\s*'?1'?\\s*=\\s*'?1|or\\s+1\\s*=\\s*1\\s*(--|#)|information_schema|sleep\\s*\\(\\s*\\d|benchmark\\s*\\()",
      "cve": "",
      "description": "SQL文を注入しDB操作・情報窃取を狙う攻撃。",
      "recommended_action": "入力値のパラメータ化/プリペアドステートメント適用、WAF導入、該当リクエスト元の遮断。",
      "reference": "https://owasp.org/www-community/attacks/SQL_Injection",
      "source": "builtin"
    },
    {
      "id": "WEB-XSS-1",
      "category": "クロスサイトスクリプティング(XSS)",
      "severity": "high",
      "binary": false,
      "pattern": "(?i)(<script[\\s>]|javascript:|onerror\\s*=|onload\\s*=|<img[^>]+onerror)",
      "cve": "",
      "description": "悪意あるスクリプトを注入し利用者ブラウザで実行させる攻撃。",
      "recommended_action": "出力エスケープ/CSP設定、入力検証の強化。",
      "reference": "https://owasp.org/www-community/attacks/xss/",
      "source": "builtin"
    },
    {
      "id": "WEB-TRAVERSAL-1",
      "category": "ディレクトリトラバーサル",
      "severity": "high",
      "binary": false,
      "pattern": "(\\.\\./\\.\\./|\\.\\.\\\\\\.\\.\\\\|/etc/passwd|/etc/shadow|c:\\\\windows\\\\|%2e%2e%2f)",
      "cve": "",
      "description": "../等で想定外のファイルへアクセスするパストラバーサル。",
      "recommended_action": "パス正規化・許可リスト方式、Webサーバの権限最小化。",
      "reference": "https://owasp.org/www-community/attacks/Path_Traversal",
      "source": "builtin"
    },
    {
      "id": "WEB-CMDI-1",
      "category": "コマンドインジェクション",
      "severity": "critical",
      "binary": false,
      "pattern": "(?i)(;\\s*(cat|ls|id|whoami|uname)\\s|\\|\\s*(cat|nc|bash|sh)\\s|\\$\\(\\s*(cat|id|whoami|uname|nc|bash|sh|curl|wget)|`\\s*(cat|id|whoami|uname|nc|bash|sh|curl|wget)[^`]*`)",
      "cve": "",
      "description": "OSコマンドを注入して任意コマンドを実行させる攻撃。",
      "recommended_action": "シェル呼び出しの排除/引数エスケープ、該当ホストの隔離と調査。",
      "reference": "https://owasp.org/www-community/attacks/Command_Injection",
      "source": "builtin"
    },
    {
      "id": "WEB-WEBSHELL-1",
      "category": "Webシェル/コード実行",
      "severity": "critical",
      "binary": false,
      "pattern": "(?i)(eval\\s*\\(\\s*base64_decode|system\\s*\\(\\s*\\$_|passthru\\s*\\(\\s*\\$_|shell_exec\\s*\\(|assert\\s*\\(\\s*\\$_)",
      "cve": "",
      "description": "Webシェル設置・サーバ側コード実行の試み。",
      "recommended_action": "アップロード先の実行権限剥奪、設置ファイルの捜索・削除、フォレンジック。",
      "reference": "https://owasp.org/www-community/attacks/Code_Injection",
      "source": "builtin"
    },
    {
      "id": "CVE-LOG4SHELL",
      "category": "Log4Shell (CVE-2021-44228)",
      "severity": "critical",
      "binary": false,
      "pattern": "(?i)\\$\\{jndi:(ldap|rmi|dns|ldaps|iiop)://",
      "cve": "CVE-2021-44228",
      "description": "Log4jのJNDIルックアップを悪用したRCE。",
