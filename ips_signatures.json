      "reference": "https://nvd.nist.gov/vuln/detail/CVE-2021-44228",
      "source": "builtin"
    },
    {
      "id": "CVE-SHELLSHOCK",
      "category": "Shellshock (CVE-2014-6271)",
      "severity": "critical",
      "binary": false,
      "pattern": "\\(\\)\\s*\\{\\s*:;\\s*\\}\\s*;",
      "cve": "CVE-2014-6271",
