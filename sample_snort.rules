# サンプル Snort/Suricata ルール（ips_rule_import.py のテスト用）
alert tcp any any -> any 80 (msg:"WEB-ATTACK SQL Injection UNION SELECT"; content:"UNION"; nocase; content:"SELECT"; nocase; classtype:web-application-attack; sid:1000001; rev:2; reference:url,owasp.org;)
alert http any any -> any any (msg:"ET WEB_SERVER Possible CVE-2021-44228 Log4j"; content:"|24 7b|jndi|3a|"; nocase; classtype:attempted-admin; sid:2034647; rev:1;)
alert tcp any any -> any any (msg:"MALWARE Suspicious Reverse Shell /bin/bash -i"; content:"/bin/bash -i"; classtype:trojan-activity; sid:1000002; rev:1;)
alert tcp any any -> any 445 (msg:"ET EXPLOIT EternalBlue SMB"; content:"|ff|SMB"; classtype:attempted-admin; sid:2024217; rev:3;)
alert udp any any -> any 53 (msg:"ET DNS Query to Suspicious TLD"; pcre:"/\.(tk|top)$/i"; classtype:bad-unknown; sid:2000003; rev:1;)
# ↓非対応行（options不足）はスキップされる
alert icmp any any -> any any (msg:"ICMP Ping";)
